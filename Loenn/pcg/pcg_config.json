{
  "server": {
    "name": "gamelab-mcp",
    "type": "sse",
    "url": "http://api.gamelabstudio.co:8765/sse",
    "api_key_header": "X-API-Key"
  },
  "project": {
    "mod_name": "PCGHelper",
    "mod_version": "1.0.0",
    "mod_prefix": "",
    "map_directory": "Maps/PCGHelper",
    "entity_catalog": "Loenn/pcg/entity_catalog.json",
    "output_directory": "Loenn/pcg/output"
  },
  "generation_presets": {
    "platforming_room": {
      "description": "Standard vanilla Celeste platforming room with spikes, springs, and collectibles",
      "entity_weights": {
        "spring": 0.15,
        "refill": 0.10,
        "spikes": 0.20,
        "jumpThru": 0.12,
        "crumbleBlock": 0.08,
        "strawberry": 0.05,
        "moveBlock": 0.05,
        "swapBlock": 0.03,
        "fallingBlock": 0.05
      },
      "tile_density": 0.3,
      "hazard_density": 0.15,
      "collectible_chance": 0.25
    },
    "puzzle_room": {
      "description": "Puzzle room with switches, gates, and moving blocks",
      "entity_weights": {
        "dashSwitch": 0.15,
        "switchGate": 0.12,
        "touchSwitch": 0.10,
        "moveBlock": 0.15,
        "swapBlock": 0.12,
        "zipMover": 0.10,
        "crumbleBlock": 0.08,
        "spikes": 0.05
      },
      "tile_density": 0.35,
      "hazard_density": 0.05,
      "collectible_chance": 0.15
    },
    "tower_climb": {
      "description": "Vertical tower climbing room with spring chains and hazards",
      "entity_weights": {
        "spring": 0.20,
        "refill": 0.12,
        "spikes": 0.15,
        "jumpThru": 0.10,
        "crumbleBlock": 0.08,
        "fallingBlock": 0.07,
        "moveBlock": 0.05
      },
      "tile_density": 0.35,
      "hazard_density": 0.20,
      "collectible_chance": 0.15,
      "vertical_priority": true
    },
    "speedrun_room": {
      "description": "Flow-oriented speedrun room with boosters and zippers",
      "entity_weights": {
        "spring": 0.20,
        "booster": 0.15,
        "refill": 0.12,
        "zipMover": 0.10,
        "moveBlock": 0.08,
        "swapBlock": 0.08,
        "jumpThru": 0.10,
        "feather": 0.05
      },
      "tile_density": 0.20,
      "hazard_density": 0.10,
      "collectible_chance": 0.10
    },
    "narrative_room": {
      "description": "Story room with NPCs and dialog triggers",
      "entity_weights": {
        "birdNpc": 0.25,
        "player": 0.05,
        "refill": 0.05
      },
      "tile_density": 0.25,
      "hazard_density": 0.0,
      "collectible_chance": 0.05
    }
  },
  "output_format": {
    "type": "json",
    "schema": {
      "rooms": [
        {
          "name": "string",
          "x": "integer",
          "y": "integer",
          "width": "integer",
          "height": "integer",
          "entities": [
            {
              "name": "string (entity type from catalog)",
              "x": "integer (relative to room)",
              "y": "integer (relative to room)",
              "width": "integer",
              "height": "integer",
              "nodes": [{"x": "integer", "y": "integer"}],
              "additional_properties": "varies by entity type"
            }
          ],
          "triggers": [
            {
              "name": "string (trigger type from catalog)",
              "x": "integer",
              "y": "integer",
              "width": "integer",
              "height": "integer"
            }
          ],
          "tilesFg": ["string rows of tile characters"],
          "tilesBg": ["string rows of tile characters"],
          "decalsFg": [{"texture": "string", "x": "integer", "y": "integer"}],
          "decalsBg": [{"texture": "string", "x": "integer", "y": "integer"}],
          "music": "string",
          "ambience": "string",
          "color": "integer",
          "windPattern": "string"
        }
      ]
    }
  }
}
